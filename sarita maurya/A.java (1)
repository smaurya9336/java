/*
O/P:  The Sum is:--115 
      The Sub is:---45
*/
interface S1{
    int AddNo(int a,int b);
}
interface S2 extends S1{
    int SubNo(int a,int b); 
}
 class A implements S2{
     public int AddNo(int a,int b){
         
         return(a+b);
     }
     public int SubNo(int a,int b){
         return(a-b);
     }

    public static void main(String args[]){
        A Obj= new A();
//S2 Obj=new A();
System.out.println("\n The Sum is:--"+Obj.AddNo(35,80));
System.out.println("\n The Sub is:--"+Obj.SubNo(35,80));

    }
}
